package p3;

import java.util.Scanner;

import p2.Linkedlist;

public class Test {

	public static void main(String[] args) {
		Linkedlist l1 = new Linkedlist();
	
		Scanner sc = new Scanner(System.in);
		while(true)
		{
		    System.out.println("Enter Choice:");
		    System.out.println("1.insert\n2.insertAtBeg\n3.insertAtPos\n4.display\n5.exit\n6.sort");

		    int choice = sc.nextInt();
		    switch(choice)
		    {
		        case 1:
		        {
		            System.out.println("Enter value to insert:");
		            int val = sc.nextInt();
		            l1.insert(val);
		            break;
		        }
		        case 2:
		        {
		            System.out.println("Enter value to insert at beginning:");
		            int val = sc.nextInt();
		            l1.insertAtBeg(val);
		            break;
		        }
		        case 3:
		        {
		            System.out.println("Enter value and position:");
		            int val = sc.nextInt();
		            int pos = sc.nextInt();
		            l1.insertAtPos(val, pos);
		            break;
		        }
		        case 4:
		        {
		            l1.display();
		            break;
		        }
		        case 5:
		        {
		            System.out.println("Exiting...");
		            sc.close();
		            return;
		        }
		        case 6:
		        {
		        	l1.sort();
		            System.out.println("Linkedlist has been sorted");
		            break;
		        }
		        case 7:
		        {
		        	int res = l1.getCount();
		            System.out.println("Number of Elements in Linkedlist:"+res);
		            break;
		        }
		        
		        default:
		        {
		            System.out.println("Invalid choice! Try again.");
		        }
		    }
		}

	}

}

package p2;

import p1.Node;

public class Queue {

	//FIFO
	Node front,rear;
	public Queue()
	{
		front=null;
	}
	
	boolean isEmpty()
	{
		if(front==null)
			return true;
		else 
			return false;
	}
	
	public void enque(int ele)
	{
		 Node newNode = new Node(ele);
		 if(isEmpty())
		 {
			 front = newNode;
		 }
		 else
		 {
			 Node temp = front;
			 while(temp.getNext()!=null)
			 {
				 temp=temp.getNext();
			 }
			 temp.setNext(newNode);
		 }
	}
	
	public void deque()
	{
		if(isEmpty())
		{
			System.out.println("Queue is Empty!!");
		}
		else
		{
			front = front.getNext();
		}
	}
	
	
	
	 
	
	
}

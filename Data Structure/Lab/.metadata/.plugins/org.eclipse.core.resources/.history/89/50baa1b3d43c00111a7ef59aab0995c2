package p2;

import p1.Node;

public class Queue {

	//FIFO
	Node front,rear;
	public Queue()
	{
		front=null;
		rear=null;
	}
	
	boolean isEmpty()
	{
		if(front==null && rear==null)
			return true;
		else 
			return false;
	}
	
	public void enque(int ele)
	{
		 Node newNode = new Node(ele);
		 if(isEmpty())
		 {
			 front = newNode;
			 rear=newNode;
		 }
		 else
		 {
			 rear.setNext(newNode);
			 rear= newNode;
		 }
	}
	
	public void deque()
	{
		if(isEmpty())
		{
			System.out.println("Queue is Empty!!");
		}
		else
		{
			front = front.getNext();
		}
	}
	
	public void display()
	{
		if(isEmpty())
		{
			System.out.println("Queue is Empty!!");
		}
		else
		{
			while(front!=null)
			{
				System.out.println(front.getData());
				front = front.getNext();
			}
		}
	}
	
	
	 
	
	
}

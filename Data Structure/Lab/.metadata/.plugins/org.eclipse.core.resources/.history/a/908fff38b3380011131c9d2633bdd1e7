package p1;

public class PriorityQueue {

		int [] arr;
		int front ;
		int rear;
		
	public PriorityQueue() {
		arr = new int[10];
		rear=-1;
		front=-1;
	}
	
	public boolean isEmpty()
	{
		if(rear==-1)
			return true;
		else
			return false;
	}

	public void insert(int ele)
	{
		if(isEmpty())
		{
			front=0;
			rear++;
			arr[rear]=ele;
			return;
		}
		
		int i=rear;
		while(ele<arr[i]&&i>=0)
		{
			arr[i+1]=arr[i];
			i--;
		}
		
		arr[i+1]=ele;
		rear++;
	}
	
	public void display()
	{
		for(int i=0;i<rear;i++)
		{
			System.out.println(arr[i]);
		}
	}
}

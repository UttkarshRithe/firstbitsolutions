package p1;

public class PriorityQueue {

		int [] arr;
		int front ;
		int rear;
		
	PriorityQueue() {
		arr = new int[10];
		rear=-1;
		front=-1;
	}
	
	boolean isEmpty()
	{
		if(rear==-1)
			return true;
		else
			return false;
	}

	void insert(int ele)
	{
		if(isEmpty())
		{
			front=0;
			rear++;
			arr[rear]=ele;
		}
		
		
		
		
	}
	
}
